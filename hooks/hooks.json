{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/scripts/ensure-playwright.js",
              "${CLAUDE_PLUGIN_DATA}"
            ],
            "timeout": 120,
            "statusMessage": "Checking playwright-core..."
          }
        ]
      }
    ]
  }
}
