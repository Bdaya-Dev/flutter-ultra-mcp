{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ext-flutter-ultra/tap",
  "title": "tap",
  "description": "ext.flutter.ultra.tap — dispatch a tap gesture on a matched widget.",
  "type": "object",
  "properties": {
    "type": { "const": "_extensionType" },
    "method": { "const": "ext.flutter.ultra.tap" },
    "status": { "const": "Success" },
    "tapped": { "type": "boolean" }
  },
  "required": ["type", "method"],
  "additionalProperties": true,
  "request": {
    "type": "object",
    "properties": {
      "key": { "type": "string" },
      "text": { "type": "string" },
      "type": { "type": "string" },
      "x": { "type": "string" },
      "y": { "type": "string" },
      "focused": { "type": "string", "enum": ["true"] }
    },
    "additionalProperties": false
  }
}
