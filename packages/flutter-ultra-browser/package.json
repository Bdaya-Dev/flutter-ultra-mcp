    "typecheck": "tsc -b --noEmit",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "playwright-core": "^1.49.0",
    "proper-lockfile": "^4.1.2",
