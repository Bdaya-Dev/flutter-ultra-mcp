    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "@types/proper-lockfile": "^4.1.4",
    "playwright": "^1.49.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.6"
  }
}
