    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "rimraf": "^6.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.7"
  }
