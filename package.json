{
  "name": "@bdayadev/flutter-ultra-mcp",
  "version": "1.17.2",
  "description": "Flutter Ultra MCP plugin monorepo â€” 8 MCP servers + ultra_flutter Dart packages + skills for Claude Code.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/Bdaya-Dev/flutter-ultra-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bdaya-Dev/flutter-ultra-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Bdaya-Dev/flutter-ultra-mcp/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.0",
  "workspaces": [
    "packages/*",
    "shared/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "bundle": "node scripts/bundle.mjs",
    "prepare": "npm run build --if-present || true",
    "test:e2e:web": "vitest run tests/e2e/web/",
    "test:e2e:oidc": "vitest run tests/e2e/oidc/",
    "test:dogfood": "vitest run tests/e2e/dogfood/",
    "test:e2e:plugin-deps": "vitest run tests/e2e/dogfood/plugin-deps.test.ts"
  },
  "dependencies": {
    "playwright-core": "^1.49.0",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^9.39.4",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/exec": "7.1.0",
    "@semantic-release/git": "10.0.1",
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.0.0",
    "prettier": "^3.3.0",
    "rimraf": "^6.0.0",
    "semantic-release": "25.0.3",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "hono": ">=4.12.21",
    "vite": ">=6.4.2"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    ".claude-plugin/",
    ".mcp.json",
    "scripts/ensure-plugin-deps.js",
    "skills/",
    "packages/*/dist/",
    "packages/*/package.json",
    "packages/*/README.md",
    "packages/*/sidecars/",
    "shared/*/dist/",
    "shared/*/package.json",
    "shared/*/README.md",
    "dart/*/lib/",
    "dart/*/pubspec.yaml",
    "dart/*/README.md",
    "dart/*/CHANGELOG.md",
    "dart/*/EXTENSIONS.md",
    "docs/",
    "examples/*/lib/",
    "examples/*/pubspec.yaml",
    "examples/*/web/",
    "examples/*/README.md",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md"
  ]
}
